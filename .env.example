# ─── Required secrets ────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token from @BotFather, and your chat ID (see README step 2-3)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=987654321

# ─── Optional knobs (defaults shown — uncomment to override) ─────────────────
# Claude model used to score job relevance (cheap/fast model recommended)
# ANALYZER_MODEL=claude-haiku-4-5-20251001

# Claude model used to write cover letters (stronger model recommended)
# COVER_LETTER_MODEL=claude-sonnet-4-6

# Minimum AI score (1-10) for a job to count as relevant
# MIN_RELEVANCE_SCORE=4

# How often the scheduler runs (node-cron syntax). Default: hourly at :00
# CRON_SCHEDULE=0 * * * *

# A notified job not seen in any scrape for this many hours is marked expired
# EXPIRY_THRESHOLD_HOURS=72

# Parallel Claude analysis requests (raise carefully — watch rate limits)
# ANALYSIS_CONCURRENCY=2

# Parallel browser workers when scraping sources / fetching descriptions
# SCRAPE_CONCURRENCY=4

# Port for the web GUI (npm run gui)
# GUI_PORT=3000
